# SQLite: файл БД. На проде укажите путь на постоянном диске (Railway Volume, Docker volume),
# иначе при новом деплое контейнера база из образа будет пустой.
# Пример Railway: примонтировать том в /data и задать одно из:
#   DATA_DIR=/data
# или полный путь:
#   SQLITE_PATH=/data/yuristblog.sqlite
# Локально по умолчанию: server/data/yuristblog.sqlite
# SQLITE_PATH=C:\\path\\to\\custom.db
# DATA_DIR=/data

# JWT secret (change this to a strong random string in production!)
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Server port (Railway sets PORT automatically, this is fallback)
SERVER_PORT=3001

# Client URL for CORS (not needed in production — same origin)
CLIENT_URL=http://localhost:8080

# Node environment (development | production)
NODE_ENV=development
